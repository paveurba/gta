# Game server port (host)
GAME_PORT=7788

# Use env vars instead of server.toml (true/false)
ALTV_USE_ENV_CONFIG=false

# Voice server (when using: docker compose --profile voice up)
PUBLIC_IP=192.168.31.84
VOICE_SECRET=1234567890

# MySQL (when using: docker compose --profile db up)
# Option A: separate vars (used by docker-compose for the altv-server container)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=altv
MYSQL_USER=altv
MYSQL_PASSWORD=altv
MYSQL_PORT=3899
# Option B: single connection string (alt:V community style, see mysql2-wrapper)
# MYSQL_CONNECTION_STRING=mysql://user:password@host:3306/database?charset=utf8mb4
