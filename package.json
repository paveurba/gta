{
  "name": "gta-rebar-rewrite",
  "version": "1.0.0",
  "private": true,
  "description": "Clean alt:V rewrite with Rebar-style modular architecture and MySQL",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepare:resource": "cp resources/rebar/package.json dist/package.json"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.5.0",
    "mysql2": "^3.15.3"
  },
  "devDependencies": {
    "@altv/types-client": "^16.4.3",
    "@altv/types-shared": "^16.4.3",
    "@altv/types-server": "^16.4.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
